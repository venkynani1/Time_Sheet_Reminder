# Render backend configuration. Copy to .env only for local development.
PORT=5000
CLIENT_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
TIMEZONE=Asia/Kolkata

# Optional free Telegram Bot channel. Leave disabled unless configured.
EMAIL_ENABLED=true
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# Optional future paid SMS provider. Disabled and unused by default.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
