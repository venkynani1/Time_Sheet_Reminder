# Render backend configuration. Copy to .env only for local development.
PORT=5000
CLIENT_URL=http://localhost:5173
APP_BASE_URL=http://localhost:5173
TIMEZONE=Asia/Kolkata

# Primary Render-compatible email provider: Gmail API over HTTPS.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=timesheetreminderr@gmail.com

# Optional legacy SMTP values. Gmail API sending does not use these by default.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Optional free Telegram Bot channel. Leave disabled unless configured.
EMAIL_ENABLED=true
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# Optional future paid SMS provider. Disabled and unused by default.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
